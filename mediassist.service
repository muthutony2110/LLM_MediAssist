[Unit]
Description=MediAssist FastAPI Application
After=network.target

[Service]
User=ubuntu
WorkingDirectory=/home/ubuntu/medical_chatbot
EnvironmentFile=/home/ubuntu/medical_chatbot/.env
ExecStart=/home/ubuntu/medical_chatbot/.venv/bin/uvicorn main:app --host 0.0.0.0 --port 8000 --workers 2
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
